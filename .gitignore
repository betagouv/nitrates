# Local docker-compose override (ports, dev-only tweaks)
docker-compose.override.yml

# Multi-agent local: syndication des ports + overrides compose par role -- jamais versionne
PORTS.local.md
docker-compose.*.local.yml

# Rapports de pentest local -- jamais versionne (details d'attaque + creds de test)
RAPPORT_PENTEST_*.md

# Claude Code workspace (memoire locale, plans, worktrees) -- jamais versionne
.claude/

# Captures Playwright nitrates (regenerables, lourd)
envergo/nitrates/scripts/validation/out_simu/
envergo/nitrates/scripts/validation/out_yaml/

# Scripts devops contenant des donnees RH (emails equipe pour provision_admin)
envergo/nitrates/scripts/provision_team.sh
# Dumps DB devops (regenerables via dumpdata)
/branches_validation_dump.json

# Override compose local par agent (syndication multi-worktrees, cf PORTS.local.md)
docker-compose.*.local.yml
PORTS.local.md

# Artefacts générés de capture validation couvert (carte #140) — régénérables
e2e/nitrates/_capture_couvert_manifeste.json
e2e/nitrates/_captures_couvert/
# idem pour la capture ZAR Grand Est (carte #140)
e2e/nitrates/_capture_zar_manifeste.json
e2e/nitrates/_captures_zar/
# idem pour la capture PAR Grand Est (carte #140)
e2e/nitrates/_capture_par_ge_manifeste.json
e2e/nitrates/_captures_par_ge/

# Crops PNG du board Miro (générés par match_and_crop.py, ~10M) — régénérables,
# déjà ingérés dans le validateur. On versionne board.svg + scripts, pas les PNG.
envergo/nitrates/specs/snapshot_miro/arbre_complet/*/crops_named/*.png
envergo/nitrates/specs/snapshot_miro/arbre_complet/*/feuilles_couvert_textes.json
# idem crops ZAR Grand Est (régénérables, déjà ingérés ; garder widgets.json + scripts)
envergo/nitrates/specs/snapshot_miro/par_zar_grand_est/*/crops_named_zar/*.png
# idem crops PAR Grand Est (régénérables, déjà ingérés ; garder mapping + scripts)
envergo/nitrates/specs/snapshot_miro/par_zar_grand_est/*/crops_named_par/*.png
# Export SVG brut du board Miro (lourd, trituré par les hooks) — garder widgets.json
envergo/nitrates/specs/snapshot_miro/arbre_complet/*/board.svg
envergo/nitrates/specs/snapshot_miro/par_zar_grand_est/*/board.svg

# Scripts Playwright de debug/inspection ponctuels (worktree #140) — non versionnés
/inspect*.mjs
/shot_*.mjs
/check_*.mjs
/test_*.mjs
